@{
    ViewData["Title"] = "Hoş Geldiniz";
}

<style>
    .hero-section {
        position: relative;
        min-height: 90vh;
        background: linear-gradient(135deg, rgba(11, 14, 26, 0.95), rgba(28, 34, 66, 0.7)), 
                    url('https://images.unsplash.com/photo-1574629810360-7efbb2278458?w=1600&q=80') center/cover no-repeat;
        display: flex;
        align-items: center;
        overflow: hidden;
        margin-top: -1rem;
    }

    .hero-content {
        z-index: 2;
        padding: 5rem 0;
    }

    .hero-badge {
        display: inline-block;
        padding: 0.5rem 1.25rem;
        background: rgba(61, 90, 254, 0.15);
        border: 1px solid rgba(61, 90, 254, 0.3);
        border-radius: 50px;
        color: var(--accent-color);
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 2rem;
        animation: fadeInUp 0.8s ease-out;
    }

    .display-1 {
        font-weight: 900;
        letter-spacing: -2px;
        background: linear-gradient(to right, #fff, #adb5bd);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 1.5rem;
        animation: fadeInUp 1s ease-out;
    }

    .lead-text {
        font-size: 1.25rem;
        color: var(--text-secondary);
        max-width: 600px;
        margin-bottom: 3rem;
        animation: fadeInUp 1.2s ease-out;
    }

    .cta-group {
        display: flex;
        gap: 1.5rem;
        animation: fadeInUp 1.4s ease-out;
    }

    .btn-hero {
        padding: 1rem 2.5rem;
        border-radius: 50px;
        font-weight: 700;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        font-size: 1.1rem;
    }

    .btn-hero-primary {
        background-color: var(--accent-color);
        color: white;
        box-shadow: 0 10px 20px rgba(61, 90, 254, 0.3);
    }

    .btn-hero-outline {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border);
        color: white;
        backdrop-filter: blur(5px);
    }

    .btn-hero:hover {
        transform: translateY(-5px);
        color: white;
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Floating Elements */
    .hero-shapes div {
        position: absolute;
        border-radius: 50%;
        background: linear-gradient(45deg, var(--accent-color), #7c4dff);
        filter: blur(80px);
        opacity: 0.2;
        z-index: 1;
    }

    .shape-1 { width: 400px; height: 400px; top: -100px; right: -100px; }
    .shape-2 { width: 300px; height: 300px; bottom: -50px; left: -100px; }
</style>

<div class="hero-section">
    <div class="hero-shapes">
        <div class="shape-1"></div>
        <div class="shape-2"></div>
    </div>
    
    <div class="container hero-content">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <span class="hero-badge">En Gelişmiş Futbol Platformu</span>
                <h1 class="display-1">Geleceğin Yıldızlarını <br> Bugün Keşfedin.</h1>
                <p class="lead-text">
                    InterFullMarkt ile dünya genelindeki binlerce oyuncuyu, kulübü ve transfer piyasasını en ince detayına kadar takip edin. Veriye dayalı scouting artık parmaklarınızın ucunda.
                </p>
                <div class="cta-group">
                    <a asp-controller="Players" asp-action="Index" class="btn btn-hero btn-hero-primary">
                        <i class="bi bi-search me-2"></i> Keşfetmeye Başla
                    </a>
                    <a asp-controller="News" asp-action="Index" class="btn btn-hero btn-hero-outline">
                        <i class="bi bi-newspaper me-2"></i> Haber Bülteni
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4 py-5 text-center">
        <div class="col-md-4">
            <div class="p-4 rounded-4" style="background: var(--card-bg); border: 1px solid var(--border);">
                <i class="bi bi-graph-up-arrow text-primary fs-1 mb-3"></i>
                <h4 class="fw-bold">Piyasa Analizi</h4>
                <p class="text-secondary small">Oyuncuların değer değişimlerini ve transfer eğilimlerini gerçek zamanlı takip edin.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 rounded-4" style="background: var(--card-bg); border: 1px solid var(--border);">
                <i class="bi bi-shield-check text-success fs-1 mb-3"></i>
                <h4 class="fw-bold">Resmi Veriler</h4>
                <p class="text-secondary small">Kulüpler ve oyuncular hakkında en doğru ve güncel veritabanına erişin.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 rounded-4" style="background: var(--card-bg); border: 1px solid var(--border);">
                <i class="bi bi-lightning-charge text-warning fs-1 mb-3"></i>
                <h4 class="fw-bold">Hızlı Erişim</h4>
                <p class="text-secondary small">Akıllı arama algoritmalarımız sayesinde aradığınız bilgiye saniyeler içinde ulaşın.</p>
            </div>
        </div>
    </div>
</div>
