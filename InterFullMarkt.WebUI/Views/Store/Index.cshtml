@{
    ViewData["Title"] = "Mağaza";
}

<div class="row mb-5">
    <div class="col-12 text-center">
        <h1 class="display-4 fw-bold text-primary"><i class="bi bi-cart-check"></i> InterFullMarkt Store</h1>
        <p class="text-secondary fs-5">Orijinal kulüp formaları, kramponlar ve taraftar ürünleri</p>
    </div>
</div>

<div class="row g-4">
    <!-- Ürün 1 -->
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-lg" style="background-color: #1a1f3a;">
            <img src="https://images.unsplash.com/photo-1580087433295-ab2600c1030e?w=500&q=80" class="card-img-top" alt="Forma" style="height: 250px; object-fit: cover;">
            <div class="card-body text-center">
                <h5 class="card-title text-white fw-bold">Elite İç Saha Forması 24/25</h5>
                <h3 class="text-warning my-3">120.00 €</h3>
                <button class="btn btn-primary w-100 rounded-pill"><i class="bi bi-cart-plus"></i> Sepete Ekle</button>
            </div>
        </div>
    </div>
    <!-- Ürün 2 -->
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-lg" style="background-color: #1a1f3a;">
            <img src="https://images.unsplash.com/photo-1628803522204-6294d1d44111?w=500&q=80" class="card-img-top" alt="Krampon" style="height: 250px; object-fit: cover;">
            <div class="card-body text-center">
                <h5 class="card-title text-white fw-bold">Profesyonel Maç Kramponu</h5>
                <h3 class="text-warning my-3">249.99 €</h3>
                <button class="btn btn-primary w-100 rounded-pill"><i class="bi bi-cart-plus"></i> Sepete Ekle</button>
            </div>
        </div>
    </div>
    <!-- Ürün 3 -->
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-lg" style="background-color: #1a1f3a;">
            <img src="https://images.unsplash.com/photo-1553152531-64ebbf48bc05?w=500&q=80" class="card-img-top" alt="Top" style="height: 250px; object-fit: cover;">
            <div class="card-body text-center">
                <h5 class="card-title text-white fw-bold">Şampiyonlar Ligi Resmi Maç Topu</h5>
                <h3 class="text-warning my-3">150.00 €</h3>
                <button class="btn btn-primary w-100 rounded-pill"><i class="bi bi-cart-plus"></i> Sepete Ekle</button>
            </div>
        </div>
    </div>
</div>