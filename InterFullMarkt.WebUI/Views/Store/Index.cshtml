@model List<InterFullMarkt.Domain.Entities.Product>
@{
    ViewData["Title"] = "Mağaza";
}

<div class="row mb-5 pt-4">
    <div class="col-12 text-center">
        <h1 class="display-3 fw-bold text-white mb-2">InterFullMarkt <span class="text-primary">Store</span></h1>
        <p class="text-secondary fs-5 mx-auto" style="max-width: 600px;">
            Orijinal kulüp formaları, profesyonel ekipmanlar ve taraftar koleksiyonları ile sahaya hükmedin.
        </p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-center gap-2 flex-wrap">
        <button class="btn btn-outline-secondary rounded-pill px-4 active">Tümü</button>
        <button class="btn btn-outline-secondary rounded-pill px-4">Forma</button>
        <button class="btn btn-outline-secondary rounded-pill px-4">Krampon</button>
        <button class="btn btn-outline-secondary rounded-pill px-4">Aksesuar</button>
    </div>
</div>

<div class="row g-4 pb-5">
    @foreach (var product in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-lg position-relative overflow-hidden group" style="background-color: var(--card-bg); border-radius: 24px;">
                @if (product.IsFeatured)
                {
                    <div class="position-absolute top-0 end-0 m-3 z-3">
                        <span class="badge bg-primary rounded-pill px-3 py-2 shadow-lg">Popüler</span>
                    </div>
                }
                
                <div class="overflow-hidden" style="height: 300px;">
                    <img src="@(product.ImageUrl ?? "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=800&q=80")" 
                         class="card-img-top w-100 h-100 transition-transform duration-500 hover-scale-110" 
                         alt="@product.Name" 
                         style="object-fit: cover;">
                </div>
                
                <div class="card-body p-4 d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="text-primary fw-bold small text-uppercase tracking-wider">@product.Category</span>
                        <div class="text-warning small">
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                        </div>
                    </div>
                    
                    <h4 class="card-title text-white fw-bold mb-3">@product.Name</h4>
                    <p class="text-secondary small mb-4 flex-grow-1">@product.Description</p>
                    
                    <div class="mt-auto pt-3 border-top border-secondary border-opacity-25">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-white fs-4 fw-bold">@product.Price.Amount.ToString("N2") @product.Price.Currency</span>
                            <small class="text-success small">Stokta Var</small>
                        </div>
                        
                        <button onclick="addToCart('@product.Id')" class="btn btn-primary w-100 rounded-pill py-3 fw-bold transition-all hover-translate-y-n2 shadow-lg d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-cart-plus-fill fs-5"></i> Sepete Ekle
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .hover-scale-110:hover { transform: scale(1.1); }
    .duration-500 { transition-duration: 0.5s; }
    .hover-translate-y-n2:hover { transform: translateY(-2px); }
    .tracking-wider { letter-spacing: 0.1em; }
</style>