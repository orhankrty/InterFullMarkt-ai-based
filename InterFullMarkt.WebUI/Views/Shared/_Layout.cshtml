<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InterFullMarkt</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- CSS Kütüphaneleri -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        :root {
            --primary-bg: #0b0e1a;
            --card-bg: #161b33;
            --header-bg: #1c2242;
            --accent-color: #3d5afe;
            --text-main: #f8f9fa;
            --text-secondary: #adb5bd;
            --text-muted: #6c757d;
            --gold: #ffd700;
            --glass: rgba(255, 255, 255, 0.05);
            --border: rgba(255, 255, 255, 0.1);
        }

        body { 
            background-color: var(--primary-bg); 
            color: var(--text-main); 
            font-family: 'Inter', sans-serif;
            line-height: 1.6;
            overflow-x: hidden;
        }

        .navbar { 
            background-color: var(--header-bg) !important; 
            border-bottom: 1px solid var(--border);
            padding: 1rem 0;
            backdrop-filter: blur(10px);
        }

        .navbar-brand {
            font-weight: 800;
            letter-spacing: -0.5px;
            font-size: 1.5rem;
        }

        .nav-link {
            font-weight: 500;
            color: var(--text-secondary) !important;
            transition: all 0.2s ease;
        }

        .nav-link:hover {
            color: var(--text-main) !important;
            transform: translateY(-1px);
        }

        .dropdown-menu {
            background-color: var(--header-bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            margin-top: 10px;
        }

        .dropdown-item {
            color: var(--text-secondary);
            padding: 0.75rem 1.5rem;
        }

        .dropdown-item:hover {
            background-color: var(--accent-color);
            color: white;
        }

        /* Global Readability Improvements */
        h1, h2, h3, h4, h5, h6 { color: #ffffff; font-weight: 700; }
        .text-secondary { color: #b0b0b0 !important; }
        .text-muted { color: #808080 !important; }
        
        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .btn-primary {
            background-color: var(--accent-color);
            border-color: var(--accent-color);
            font-weight: 600;
        }

        /* Premium Scrollbar */
        ::-webkit-scrollbar { width: 10px; }
        ::-webkit-scrollbar-track { background: var(--primary-bg); }
        ::-webkit-scrollbar-thumb { background: var(--header-bg); border-radius: 5px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--accent-color); }
    </style>
</head>
<body>
    
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <i class="bi bi-globe-europe-africa fs-3"></i> InterFullMarkt
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door"></i> Anasayfa</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Players" asp-action="Index"><i class="bi bi-people"></i> Oyuncular & Takımlar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="News" asp-action="Index"><i class="bi bi-newspaper"></i> Haber Bülteni</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Store" asp-action="Index"><i class="bi bi-cart3"></i> Mağaza</a>
                    </li>
                </ul>
                <ul class="navbar-nav align-items-center">
                    <li class="nav-item me-3">
                        <a href="javascript:void(0)" class="nav-link position-relative px-2" data-bs-toggle="offcanvas" data-bs-target="#cartDrawer">
                            <i class="bi bi-cart3 fs-4"></i>
                            <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">0</span>
                        </a>
                    </li>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white d-flex align-items-center gap-2" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle fs-5"></i> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><a class="dropdown-item d-flex align-items-center gap-2" asp-controller="Admin" asp-action="Index"><i class="bi bi-shield-lock text-warning"></i> Admin Paneli</a></li>
                                }
                                <li><a class="dropdown-item d-flex align-items-center gap-2" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 text-info"></i> Dashboard</a></li>
                                <li><hr class="dropdown-divider border-secondary opacity-25"></li>
                                <li><a class="dropdown-item d-flex align-items-center gap-2 text-danger" asp-controller="Auth" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> Çıkış Yap</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-primary px-4 rounded-pill shadow-lg" asp-controller="Auth" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Giriş Yap
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main" style="min-height: 85vh;">
        @RenderBody()
    </main>

    <footer class="text-center py-5 text-secondary" style="background-color: #080a14; border-top: 1px solid var(--border);">
        <div class="container">
            <div class="row g-4 align-items-center">
                <div class="col-md-4 text-md-start">
                    <h5 class="text-white mb-3">InterFullMarkt</h5>
                    <p class="small">Futbol dünyasının kalbine yolculuk yapın. Oyuncular, kulüpler ve en son haberler burada.</p>
                </div>
                <div class="col-md-4">
                    <div class="d-flex justify-content-center gap-3 fs-4">
                        <i class="bi bi-twitter-x"></i>
                        <i class="bi bi-instagram"></i>
                        <i class="bi bi-youtube"></i>
                        <i class="bi bi-facebook"></i>
                    </div>
                </div>
                <div class="col-md-4 text-md-end">
                    <p class="mb-0">&copy; @DateTime.Now.Year - InterFullMarkt Platformu</p>
                    <small>Tüm Hakları Saklıdır.</small>
                </div>
            </div>
        </div>
    </footer>

    <partial name="_CartDrawer" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>