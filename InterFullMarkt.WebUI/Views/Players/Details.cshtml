@model InterFullMarkt.Application.Features.Players.Queries.GetPlayerById.GetPlayerByIdResult

@{
    ViewData["Title"] = $"{Model.FullName} - Oyuncu DetaylarÄ±";
    var age = Model.Age;
}

<style>
    :root {
        --primary-color: #0066ff;
        --secondary-color: #ffd700;
        --dark-bg: #0a0e27;
        --card-bg: #1a1f3a;
        --text-muted: #e0e0e0;
    }

    .player-header {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
        color: white;
        padding: 3rem 1rem;
        border-radius: 1rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    }

    .player-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background-color: rgba(255, 255, 255, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        font-weight: bold;
        border: 3px solid white;
    }

    .stat-card {
        background-color: var(--card-bg);
        border-left: 4px solid var(--primary-color);
        padding: 1.5rem;
        border-radius: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .stat-card h6 {
        color: var(--text-muted);
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.5rem;
    }

    .stat-card .value {
        font-size: 1.75rem;
        font-weight: bold;
        color: var(--secondary-color);
    }

    .market-value-highlight {
        background-color: rgba(255, 215, 0, 0.1);
        border-left-color: var(--secondary-color) !important;
    }

    .chart-container {
        background-color: var(--card-bg);
        border-radius: 1rem;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    }

    .tabs {
        display: flex;
        gap: 0;
        margin-bottom: 1.5rem;
        border-bottom: 2px solid rgba(255, 255, 255, 0.1);
    }

    .tab-button {
        flex: 1;
        padding: 1rem;
        background: transparent;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        border-bottom: 3px solid transparent;
        transition: all 0.3s ease;
        text-transform: uppercase;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.1em;
    }

    .tab-button.active {
        color: var(--secondary-color);
        border-bottom-color: var(--secondary-color);
    }

    .tab-button:hover {
        color: var(--primary-color);
    }

    .transfer-table {
        width: 100%;
        background-color: var(--card-bg);
        border-radius: 0.5rem;
        overflow: hidden;
    }

    .transfer-table thead {
        background-color: rgba(0, 102, 255, 0.15);
    }

    .transfer-table td {
        padding: 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        color: var(--text-muted);
    }

    .transfer-table tbody tr:hover {
        background-color: rgba(0, 102, 255, 0.05);
    }

    .position-badge {
        display: inline-block;
        background-color: var(--primary-color);
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.875rem;
        font-weight: 600;
    }

    .back-button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--primary-color);
        text-decoration: none;
        margin-bottom: 1.5rem;
        transition: all 0.3s ease;
    }

    .back-button:hover {
        color: var(--secondary-color);
        transform: translateX(-3px);
    }

    /* AI Scout Styles */
    .ai-scout-card {
        background: linear-gradient(135deg, rgba(61, 90, 254, 0.1), rgba(28, 34, 66, 0.95));
        border: 1px solid var(--accent-color);
        border-radius: 24px;
        padding: 2rem;
        position: relative;
        overflow: hidden;
    }
    .ai-scout-card::after {
        content: 'AI SCOUT';
        position: absolute;
        top: 20px;
        right: 20px;
        font-size: 3rem;
        font-weight: 900;
        opacity: 0.05;
        font-style: italic;
    }
    .pro-tag {
        background: rgba(0, 102, 255, 0.1);
        border: 1px solid rgba(0, 102, 255, 0.3);
        padding: 5px 15px;
        border-radius: 50px;
        font-size: 0.85rem;
        margin-right: 8px;
        margin-bottom: 8px;
        display: inline-block;
    }
    .similar-item {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        padding: 10px 15px;
        margin-bottom: 10px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
</style>

<div class="container mt-4">
    <a href="@Url.Action("Index")" class="back-button">
        <i class="bi bi-arrow-left"></i> Oyunculara DÃ¶n
    </a>

    <!-- Player Header -->
    <div class="player-header">
        <div class="row align-items-center">
            <div class="col-md-2 text-center mb-3 mb-md-0">
                <div class="player-avatar">
                    @Model.FullName.First().ToString().ToUpper()
                </div>
            </div>
            <div class="col-md-10">
                <div class="row">
                    <div>
                        <h1 class="mb-2">
                            @Model.FullName
                            <span class="position-badge">@Model.Position</span>
                        </h1>
                        <p class="mb-1" style="font-size: 1.1rem;">
                            <span style="font-size: 2rem;">@Model.NationalityFlag</span>
                            @Model.Nationality
                        </p>
                        @if (!string.IsNullOrEmpty(Model.ClubName))
                        {
                            <p class="mb-0" style="opacity: 0.9;">
                                <i class="bi bi-building"></i> @Model.ClubName
                            </p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <h6>YaÅŸ</h6>
                <div class="value">@Model.Age</div>
                <small class="text-muted">@Model.DateOfBirth.ToString("d MMMM yyyy")</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <h6>Boy</h6>
                <div class="value">@Model.Height cm</div>
                <small class="text-muted">Kilo: @Model.Weight kg</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <h6>Tercih Edilen Ayak</h6>
                <div class="value">@Model.PreferredFoot</div>
                <small class="text-muted">Dominant foot</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card market-value-highlight">
                <h6>Piyasa DeÄŸeri</h6>
                <div class="value">@Model.MarketValue</div>
                <small class="text-muted">Son gÃ¼ncelleme: @Model.CreatedDate.ToString("d MMMM yyyy")</small>
            </div>
        </div>
    </div>

    @if (Model.JerseyNumber.HasValue)
    {
        <div class="alert alert-info mb-4" style="background-color: rgba(0, 102, 255, 0.1); border-left: 4px solid var(--primary-color);">
            <strong>Forma No:</strong> #@Model.JerseyNumber
        </div>
    }

    <!-- Tabs Navigation -->
    <div style="background-color: var(--card-bg); border-radius: 1rem; padding: 1rem; margin-bottom: 2rem;">
        <div class="tabs">
            <button class="tab-button active" onclick="showTab(event, 'market-history')">
                <i class="bi bi-graph-up"></i> Piyasa Tarihi
            </button>
            <button class="tab-button" onclick="showTab(event, 'transfers')">
                <i class="bi bi-shuffle"></i> Transfer GeÃ§miÅŸi
            </button>
            <button class="tab-button" onclick="showTab(event, 'stats')">
                <i class="bi bi-bar-chart"></i> Statistikler
            </button>
        </div>
    </div>

    <!-- Tab Contents -->

    <div id="market-history" class="tab-content" style="display: block;">
        <div class="row">
            <div class="col-lg-8">
                <div class="chart-container">
                    <h3 class="mb-4">Piyasa DeÄŸeri Tarihi (Son 12 Ay)</h3>
                    <canvas id="marketValueChart" style="max-height: 400px;"></canvas>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="ai-scout-card h-100">
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <i class="bi bi-robot text-primary fs-3"></i>
                        <h4 class="mb-0 fw-bold">Premium AI Raporu</h4>
                    </div>

                    <div class="mb-4">
                        <div class="stat-label mb-2">Scouting Kategorisi</div>
                        <div class="h5 fw-bold text-accent">@Model.AiScoutingCategory</div>
                    </div>

                    <div class="mb-4">
                        <div class="stat-label mb-2">Ã–ne Ã‡Ä±kan Ã–zellikler</div>
                        <div class="d-flex flex-wrap">
                            @foreach (var pro in Model.AiPros)
                            {
                                <span class="pro-tag"><i class="bi bi-check2 text-success me-1"></i> @pro</span>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="stat-label mb-2">Benzer Arketip</div>
                        @foreach (var similar in Model.AiSimilarPlayers)
                        {
                            <div class="similar-item d-flex align-items-center gap-2">
                                <i class="bi bi-person-fill text-secondary"></i>
                                <span>@similar</span>
                            </div>
                        }
                    </div>

                    <div class="mt-4 p-3 bg-white rounded-4 border border-secondary border-opacity-25">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <small class="text-secondary">AI Fiyat Tahmini (12 Ay)</small>
                            <span class="badge @(Model.AiPredictionChange >= 0 ? "bg-success" : "bg-danger")">
                                @(Model.AiPredictionChange >= 0 ? "+" : "")@Model.AiPredictionChange.ToString("F1")%
                            </span>
                        </div>
                        <div class="h4 fw-bold mb-0">@Model.AiPredictedValue</div>
                        <small class="text-muted" style="font-size: 0.7rem;">@Model.AiPredictionReasoning</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Transfer History -->
    <div id="transfers" class="tab-content" style="display: none;">
        <div class="chart-container">
            <h3 class="mb-4">Transfer GeÃ§miÅŸi</h3>
            @if (Model.TransferHistory.Count > 0)
            {
                <table class="transfer-table">
                    <thead>
                        <tr>
                            <td><strong>Tarih</strong></td>
                            <td><strong>Kaynak KulÃ¼p</strong></td>
                            <td><strong>Hedef KulÃ¼p</strong></td>
                            <td><strong>Bedel</strong></td>
                            <td><strong>TÃ¼r</strong></td>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var transfer in Model.TransferHistory)
                        {
                            <tr>
                                <td>@transfer.TransferDate.ToString("d MMMM yyyy")</td>
                                <td>@transfer.FromClub</td>
                                <td>@transfer.ToClub</td>
                                <td><strong>@transfer.Fee</strong></td>
                                <td><span class="badge bg-primary">@transfer.TransferType</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info" style="background-color: rgba(0, 102, 255, 0.1); border-left: 4px solid var(--primary-color);">
                    <i class="bi bi-info-circle"></i> HenÃ¼z transfer geÃ§miÅŸi bulunmamaktadÄ±r.
                </div>
            }
        </div>
    </div>

    <!-- Statistics -->
    <div id="stats" class="tab-content" style="display: none;">
        <div class="chart-container">
            <h3 class="mb-4">DetaylÄ± Bilgiler</h3>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <strong>Milliyeti:</strong> @Model.Nationality (@Model.NationalityFlag)
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Mevkii:</strong> @Model.Position
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Boy:</strong> @Model.Height cm
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Kilo:</strong> @Model.Weight kg
                </div>
                <div class="col-md-6 mb-3">
                    <strong>AyaÄŸÄ±:</strong> @Model.PreferredFoot
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Piyasa DeÄŸeri:</strong> @Model.MarketValue
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.js"></script>
    <script>
        // Market Value Chart
        const ctx = document.getElementById('marketValueChart').getContext('2d');
        const marketHistory = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MarketValueHistory));
        
        const labels = marketHistory.map(m => m.month);
        const data = marketHistory.map(m => m.value / 1_000_000); // Convert to millions

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Piyasa DeÄŸeri (â‚¬M)',
                    data: data,
                    borderColor: '#0066ff',
                    backgroundColor: 'rgba(0, 102, 255, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 5,
                    pointBackgroundColor: '#ffd700',
                    pointBorderColor: '#0066ff',
                    pointBorderWidth: 2,
                    pointHoverRadius: 7
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        display: true,
                        labels: {
                            color: '#e0e0e0',
                            font: {
                                size: 14
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: false,
                        grid: {
                            color: 'rgba(255, 255, 255, 0.1)'
                        },
                        ticks: {
                            color: '#e0e0e0',
                            callback: function(value) {
                                return 'â‚¬' + value + 'M';
                            }
                        }
                    },
                    x: {
                        grid: {
                            color: 'rgba(255, 255, 255, 0.05)'
                        },
                        ticks: {
                            color: '#e0e0e0'
                        }
                    }
                }
            }
        });

        // Tab switching
        function showTab(event, tabName) {
            // Hide all tabs
            const tabs = document.querySelectorAll('.tab-content');
            tabs.forEach(t => t.style.display = 'none');

            // Remove active class from all buttons
            const buttons = document.querySelectorAll('.tab-button');
            buttons.forEach(b => b.classList.remove('active'));

            // Show selected tab
            document.getElementById(tabName).style.display = 'block';

            // Add active class to clicked button (currentTarget ensures icon clicks do not break behavior)
            if (event && event.currentTarget) {
                event.currentTarget.classList.add('active');
            }
        }
    </script>
}

