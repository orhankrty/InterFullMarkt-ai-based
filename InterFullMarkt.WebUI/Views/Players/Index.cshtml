@model InterFullMarkt.Application.Features.Players.Queries.GetAllPlayers.GetAllPlayersResult
@{
    ViewData["Title"] = "Oyuncular & Takımlar";
    var searchTerm = ViewData["SearchTerm"]?.ToString();
    var hasSearch = !string.IsNullOrWhiteSpace(searchTerm);
}

<style>
    .search-hero {
        padding: 4rem 0;
        background: radial-gradient(circle at top right, rgba(61, 90, 254, 0.1), transparent);
        border-radius: 24px;
        margin-bottom: 3rem;
    }

    .search-input-wrapper {
        position: relative;
        max-width: 700px;
        margin: 0 auto;
    }

    .search-input-wrapper i {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--accent-color);
        font-size: 1.5rem;
    }

    .main-search-input {
        height: 70px;
        padding-left: 60px !important;
        border-radius: 50px;
        background: var(--header-bg) !important;
        border: 2px solid var(--border) !important;
        color: white !important;
        font-size: 1.25rem;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .main-search-input:focus {
        border-color: var(--accent-color) !important;
        box-shadow: 0 0 0 0.25rem rgba(61, 90, 254, 0.25);
    }

    .section-title {
        border-left: 4px solid var(--accent-color);
        padding-left: 1rem;
        margin-bottom: 2rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Club Card Styles */
    .club-card {
        background: linear-gradient(145deg, #1c2242, #161b33);
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid var(--border);
        height: 100%;
        transition: all 0.4s ease;
    }

    .club-card:hover {
        transform: translateY(-10px);
        border-color: var(--accent-color);
        box-shadow: 0 15px 40px rgba(0,0,0,0.4);
    }

    .club-logo-container {
        height: 150px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.2);
        padding: 2rem;
    }

    .club-logo-container img {
        max-height: 100%;
        object-fit: contain;
        filter: drop-shadow(0 5px 15px rgba(0,0,0,0.3));
    }

    /* Player Card Styles (Premium) */
    .player-card {
        background: var(--card-bg);
        border-radius: 16px;
        border: 1px solid var(--border);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .player-position-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: var(--accent-color);
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .stat-label { color: #8a8fb0; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; }
    .stat-value { color: #ffffff; font-weight: 700; }

    .market-value-tag {
        background: rgba(255, 215, 0, 0.1);
        border: 1px solid rgba(255, 215, 0, 0.3);
        color: var(--gold);
        padding: 8px 15px;
        border-radius: 10px;
        font-weight: 800;
    }

    .empty-state {
        text-align: center;
        padding: 5rem 0;
    }

    .empty-state i {
        font-size: 5rem;
        color: var(--header-bg);
        margin-bottom: 2rem;
    }
</style>

<div class="container py-4">
    
    <!-- Search Section -->
    <div class="search-hero">
        <div class="text-center mb-5">
            <h2 class="display-6 fw-bold">Kimi Aramıştınız?</h2>
            <p class="text-secondary">Veritabanımızdaki oyuncuları ve kulüpleri anında keşfedin.</p>
        </div>
        
        <form method="get" class="search-input-wrapper">
            <i class="bi bi-search"></i>
            <input type="text" name="search" class="main-search-input form-control" 
                   placeholder="Oyuncu adı, kulüp veya milliyet yazın..." 
                   value="@searchTerm" autocomplete="off">
            <button type="submit" class="btn btn-primary position-absolute end-0 top-50 translate-middle-y me-2 rounded-pill px-4" style="height: 54px;">
                Ara
            </button>
        </form>
    </div>

    @if (!hasSearch)
    {
        <!-- Default Empty State -->
        <div class="empty-state">
            <i class="bi bi-rocket-takeoff"></i>
            <h3>Keşfetmeye Hazır mısınız?</h3>
            <p class="text-secondary mx-auto" style="max-width: 500px;">
                Henüz bir arama yapmadınız. Yukarıdaki kutucuğu kullanarak Galatasaray gibi bir kulüp veya Icardi gibi bir oyuncu ismini aratarak başlayabilirsiniz.
            </p>
        </div>
    }
    else
    {
        <!-- Results Section -->
        <div class="results-container">
            
            <!-- Teams Results -->
            @if (Model.Clubs != null && Model.Clubs.Any())
            {
                <div class="mb-5">
                    <h3 class="section-title"><i class="bi bi-shield-check text-primary me-2"></i> Takımlar</h3>
                    <div class="row g-4">
                        @foreach (var club in Model.Clubs)
                        {
                            <div class="col-lg-4 col-md-6">
                                <div class="club-card shadow-lg">
                                    <div class="club-logo-container">
                                        @if (!string.IsNullOrEmpty(club.LogoUrl))
                                        {
                                            <img src="@club.LogoUrl" alt="@club.Name">
                                        }
                                        else
                                        {
                                            <i class="bi bi-shield-shaded display-1 text-muted opacity-25"></i>
                                        }
                                    </div>
                                    <div class="p-4">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <h4 class="mb-0">@club.Name</h4>
                                            <span class="badge bg-dark border border-secondary">Krl: @club.FoundingYear</span>
                                        </div>
                                        <div class="mb-4 small">
                                            <p class="text-secondary mb-1"><i class="bi bi-geo-alt me-2"></i> @club.StadiumName</p>
                                            <div class="d-flex gap-2">
                                                @foreach (var color in club.Colors.Split('-'))
                                                {
                                                    <span class="badge rounded-pill px-3" style="background-color: @color.Trim(); border: 1px solid rgba(255,255,255,0.2);">@color.Trim()</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="row g-2 border-top border-secondary pt-3">
                                            <div class="col-6">
                                                <div class="stat-label">Kadro Sayısı</div>
                                                <div class="stat-value">@club.SquadCount Oyuncu</div>
                                            </div>
                                            <div class="col-6">
                                                <div class="stat-label">Kadro Değeri</div>
                                                <div class="stat-value text-warning">€@((club.TotalSquadValue ?? 0).ToString("N0"))</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Players Results -->
            <div>
                <h3 class="section-title"><i class="bi bi-person-bounding-box text-primary me-2"></i> Oyuncular (@Model.TotalCount)</h3>
                @if (!Model.Players.Any())
                {
                    <div class="alert alert-dark border-secondary py-4 text-center">
                        <i class="bi bi-search mb-2 d-block fs-2"></i>
                        Eşleşen oyuncu bulunamadı.
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var player in Model.Players)
                        {
                            <div class="col-lg-4 col-md-6">
                                <div class="player-card position-relative p-4 h-100 shadow-sm">
                                    <span class="player-position-badge">@player.Position</span>
                                    
                                    <div class="d-flex align-items-center gap-3 mb-4">
                                        <div class="rounded-circle bg-dark d-flex align-items-center justify-content-center overflow-hidden" style="width: 70px; height: 70px; border: 2px solid var(--accent-color);">
                                            @if (!string.IsNullOrEmpty(player.ImageUrl))
                                            {
                                                <img src="@player.ImageUrl" alt="@player.FullName" style="width: 100%; height: 100%; object-fit: cover;">
                                            }
                                            else
                                            {
                                                <i class="bi bi-person text-secondary fs-2"></i>
                                            }
                                        </div>
                                        <div>
                                            <h5 class="mb-0 text-white fw-bold">@player.FullName</h5>
                                            <small class="text-secondary">@player.Nationality</small>
                                        </div>
                                    </div>

                                    <div class="row g-3 mb-4">
                                        <div class="col-4">
                                            <div class="stat-label">Yaş</div>
                                            <div class="stat-value">@player.Age</div>
                                        </div>
                                        <div class="col-4 text-center">
                                            <div class="stat-label">Boy</div>
                                            <div class="stat-value">@player.Height cm</div>
                                        </div>
                                        <div class="col-4 text-end">
                                            <div class="stat-label">No</div>
                                            <div class="stat-value text-primary">#@(player.JerseyNumber ?? 0)</div>
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                            <i class="bi bi-shield-shaded text-accent"></i>
                                            <span class="text-white fw-bold">@(player.CurrentClubName ?? "Kulüpsüz")</span>
                                        </div>
                                        <div class="progress" style="height: 4px; background: rgba(255,255,255,0.05);">
                                            <div class="progress-bar bg-primary" style="width: 85%;"></div>
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mt-auto">
                                        <div class="market-value-tag">
                                            @player.MarketValue
                                        </div>
                                        <a href="@Url.Action("Details", "Players", new { id = player.Id })" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                            Detay <i class="bi bi-arrow-right ms-1"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>
