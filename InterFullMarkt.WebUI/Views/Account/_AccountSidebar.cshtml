<div class="list-group list-group-flush rounded-4 overflow-hidden border border-secondary border-opacity-25 shadow-sm">
    <a href="/Account" class="list-group-item list-group-item-action bg-dark text-white py-3 @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active bg-primary border-primary" : "")">
        <i class="bi bi-speedometer2 me-2"></i> Dashboard
    </a>
    <a href="/Account/Profile" class="list-group-item list-group-item-action bg-dark text-white py-3 @(ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active bg-primary border-primary" : "")">
        <i class="bi bi-person-gear me-2"></i> Profil Bilgileri
    </a>
    <a href="/Account/Orders" class="list-group-item list-group-item-action bg-dark text-white py-3 @(ViewContext.RouteData.Values["action"]?.ToString() == "Orders" ? "active bg-primary border-primary" : "")">
        <i class="bi bi-bag-check me-2"></i> Siparişlerim
    </a>
    <a href="/Account/Addresses" class="list-group-item list-group-item-action bg-dark text-white py-3 @(ViewContext.RouteData.Values["action"]?.ToString() == "Addresses" ? "active bg-primary border-primary" : "")">
        <i class="bi bi-geo-alt me-2"></i> Adreslerim
    </a>
    <a href="/Auth/Logout" class="list-group-item list-group-item-action bg-dark text-danger py-3">
        <i class="bi bi-box-arrow-right me-2"></i> Güvenli Çıkış
    </a>
</div>

<style>
    .list-group-item {
        border-color: rgba(255, 255, 255, 0.05);
        transition: all 0.2s ease;
    }
    .list-group-item:hover:not(.active) {
        background-color: rgba(255, 255, 255, 0.05) !important;
        padding-left: 1.5rem;
    }
</style>
