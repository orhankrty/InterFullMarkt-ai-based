@model InterFullMarkt.Domain.Entities.User
@{
    ViewData["Title"] = "Hesabım";
}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="card bg-white border-0 p-3" style="border-radius: 24px;">
                <div class="text-center py-4">
                    <div class="rounded-circle bg-primary mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                        <span class="fs-2 fw-bold text-dark">@(User.Identity?.Name?[0].ToString().ToUpper() ?? "U")</span>
                    </div>
                    <h5 class="text-dark fw-bold mb-0">@User.Identity?.Name</h5>
                    <p class="text-secondary small">@Model.Email</p>
                </div>
                <partial name="_AccountSidebar" />
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9">
            <h2 class="fw-bold mb-4">Hesap Özeti</h2>
            
            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="card h-100 bg-white border-secondary border-opacity-25 p-4 rounded-4 shadow-sm">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="p-3 bg-primary bg-opacity-10 rounded-3 text-primary">
                                <i class="bi bi-box-seam fs-4"></i>
                            </div>
                            <div>
                                <h6 class="text-secondary mb-0">Toplam Sipariş</h6>
                                <h4 class="text-dark fw-bold mb-0">@Model.Orders.Count</h4>
                            </div>
                        </div>
                        <a href="/Account/Orders" class="text-decoration-none small text-primary">Detaylı Gör <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 bg-white border-secondary border-opacity-25 p-4 rounded-4 shadow-sm">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="p-3 bg-success bg-opacity-10 rounded-3 text-success">
                                <i class="bi bi-geo-alt fs-4"></i>
                            </div>
                            <div>
                                <h6 class="text-secondary mb-0">Kayıtlı Adres</h6>
                                <h4 class="text-dark fw-bold mb-0">@Model.Addresses.Count</h4>
                            </div>
                        </div>
                        <a href="/Account/Addresses" class="text-decoration-none small text-success">Yönet <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 bg-white border-secondary border-opacity-25 p-4 rounded-4 shadow-sm text-center d-flex align-items-center justify-content-center">
                        <p class="text-secondary small mb-2">Üyelik Tarihi</p>
                        <h6 class="text-dark fw-bold">12 Mart 2024</h6>
                    </div>
                </div>
            </div>

            <!-- Recent Orders -->
            <div class="card bg-white border-secondary border-opacity-25 rounded-4 overflow-hidden">
                <div class="card-header bg-black bg-opacity-25 py-3 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">Son Siparişleriniz</h5>
                    <a href="/Account/Orders" class="btn btn-sm btn-outline-secondary rounded-pill">Tümünü Gör</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-dark table-hover mb-0 align-middle">
                            <thead class="bg-black bg-opacity-25">
                                <tr class="text-secondary small">
                                    <th class="ps-4">Sipariş No</th>
                                    <th>Tarih</th>
                                    <th>Tutar</th>
                                    <th>Durum</th>
                                    <th class="pe-4"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Orders.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="py-5 text-center text-secondary opacity-50">
                                            Henüz bir siparişiniz bulunmuyor.
                                        </td>
                                    </tr>
                                }
                                @foreach (var order in Model.Orders.OrderByDescending(o => o.OrderDate).Take(3))
                                {
                                    <tr>
                                        <td class="ps-4">#@order.Id.ToString().Substring(0, 8)</td>
                                        <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                                        <td class="text-warning fw-bold">@order.TotalAmount</td>
                                        <td><span class="badge bg-secondary">@order.Status</span></td>
                                        <td class="pe-4 text-end">
                                            <a href="/Account/Orders/@order.Id" class="btn btn-sm btn-link text-primary"><i class="bi bi-eye"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

