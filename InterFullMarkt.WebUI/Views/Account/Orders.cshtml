@model List<InterFullMarkt.Domain.Entities.Order>
@{
    ViewData["Title"] = "SipariÅŸlerim";
}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="card bg-white border-0 p-3 rounded-4">
                <partial name="_AccountSidebar" />
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9">
            <h2 class="fw-bold mb-4">SipariÅŸlerim</h2>
            
            @if (!Model.Any())
            {
                <div class="card bg-white border-secondary border-opacity-25 rounded-4 p-5 text-center shadow-lg">
                    <div class="opacity-25 mb-4">
                        <i class="bi bi-bag-x display-1"></i>
                    </div>
                    <h4 class="text-dark fw-bold">HenÃ¼z SipariÅŸiniz Yok</h4>
                    <p class="text-secondary mb-4">MaÄŸazamÄ±zdaki harika Ã¼rÃ¼nlere gÃ¶z atarak ilk sipariÅŸinizi verebilirsiniz.</p>
                    <a href="/Store" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-lg">MaÄŸazayÄ± KeÅŸfet</a>
                </div>
            }
            else
            {
                @foreach (var order in Model)
                {
                    <div class="card bg-white border-secondary border-opacity-25 rounded-4 overflow-hidden mb-4 shadow-sm">
                        <div class="card-header bg-black bg-opacity-25 py-3 px-4 d-flex justify-content-between align-items-center">
                            <div>
                                <span class="text-secondary small d-block">SipariÅŸ Tarihi</span>
                                <span class="text-dark fw-bold">@order.OrderDate.ToString("dd MMMM yyyy HH:mm")</span>
                            </div>
                            <div class="text-md-end">
                                <span class="text-secondary small d-block">SipariÅŸ No</span>
                                <span class="text-dark fw-bold">#@order.Id.ToString().Substring(0, 8).ToUpper()</span>
                            </div>
                            <div>
                                <span class="badge @(order.Status == "Completed" ? "bg-success" : "bg-primary") rounded-pill px-3">@order.Status</span>
                            </div>
                        </div>
                        <div class="card-body p-4">
                            <div class="row g-4">
                                <div class="col-md-8">
                                    <div class="d-flex gap-2 flex-wrap mb-3">
                                        @foreach (var item in order.OrderItems)
                                        {
                                            <div class="bg-black bg-opacity-25 rounded-3 p-1 position-relative" style="width: 60px; height: 60px;">
                                                <img src="@item.Product?.ImageUrl" class="w-100 h-100 rounded-2" style="object-fit: cover;" title="@item.Product?.Name">
                                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">@item.Quantity</span>
                                            </div>
                                        }
                                    </div>
                                    <p class="text-secondary small mb-0"><i class="bi bi-geo-alt me-1"></i> @order.ShippingAddress</p>
                                </div>
                                <div class="col-md-4 text-md-end d-flex flex-column justify-content-between">
                                    <div>
                                        <span class="text-secondary small d-block">Toplam Tutar</span>
                                        <span class="text-warning fs-4 fw-bold">@order.TotalAmount.ToString()</span>
                                    </div>
                                    <a href="/Checkout/Success/@order.Id" class="btn btn-outline-primary btn-sm rounded-pill px-4 mt-3">DetaylarÄ± GÃ¶r</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

