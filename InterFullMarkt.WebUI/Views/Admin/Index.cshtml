@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .admin-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 16px;
        transition: transform 0.3s ease;
        overflow: hidden;
    }
    .admin-card:hover {
        transform: translateY(-5px);
        border-color: var(--accent-color);
    }
    .stat-icon {
        width: 60px;
        height: 60px;
        background: rgba(61, 90, 254, 0.1);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent-color);
        font-size: 1.5rem;
    }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-5 fw-bold text-white mb-2">Yönetim Paneli</h1>
            <p class="text-secondary">Sistem genelindeki tüm verileri buradan kontrol edebilirsiniz.</p>
        </div>
        <div class="text-end">
            <span class="badge bg-primary px-3 py-2 rounded-pill">Hoş Geldiniz, Admin</span>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="admin-card p-4 d-flex align-items-center gap-4">
                <div class="stat-icon">
                    <i class="bi bi-shield-check"></i>
                </div>
                <div>
                    <h3 class="mb-0 fw-bold">@ViewBag.ClubCount</h3>
                    <div class="text-secondary small text-uppercase fw-semibold">Toplam Takım</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="admin-card p-4 d-flex align-items-center gap-4">
                <div class="stat-icon">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <h3 class="mb-0 fw-bold">@ViewBag.PlayerCount</h3>
                    <div class="text-secondary small text-uppercase fw-semibold">Aktif Oyuncu</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="admin-card p-4 d-flex align-items-center gap-4">
                <div class="stat-icon text-success" style="background: rgba(46, 213, 115, 0.1);">
                    <i class="bi bi-currency-euro"></i>
                </div>
                <div>
                    <h3 class="mb-0 fw-bold">€1.2B</h3>
                    <div class="text-secondary small text-uppercase fw-semibold">Piyasa Değeri</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Management Sections -->
    <div class="row g-4">
        <div class="col-md-6">
            <div class="admin-card h-100">
                <div class="p-4 border-bottom border-secondary" style="background: rgba(255,255,255,0.02);">
                    <h5 class="mb-0"><i class="bi bi-shield-shaded me-2 text-primary"></i> Takım Yönetimi</h5>
                </div>
                <div class="p-4">
                    <p class="text-secondary mb-4">Yeni kulüpler ekleyin, mevcut takımların stadyum, bütçe ve renk bilgilerini güncelleyin.</p>
                    <a href="/Admin/Teams" class="btn btn-outline-primary w-100 py-2 rounded-pill">
                        Takımları Yönet <i class="bi bi-chevron-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="admin-card h-100">
                <div class="p-4 border-bottom border-secondary" style="background: rgba(255,255,255,0.02);">
                    <h5 class="mb-0"><i class="bi bi-person-badge me-2 text-primary"></i> Oyuncu Yönetimi</h5>
                </div>
                <div class="p-4">
                    <p class="text-secondary mb-4">Veritabanındaki oyuncuları güncelleyin, yeni transferler ekleyin veya oyuncu bilgilerini düzenleyin.</p>
                    <a href="/Admin/Players" class="btn btn-outline-primary w-100 py-2 rounded-pill">
                        Oyuncuları Yönet <i class="bi bi-chevron-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
