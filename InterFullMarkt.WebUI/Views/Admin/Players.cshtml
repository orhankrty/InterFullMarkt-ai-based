@model List<InterFullMarkt.Application.DTOs.PlayerDto>
@{
    ViewData["Title"] = "Oyuncu Yönetimi";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/Admin" class="text-decoration-none text-secondary">Yönetim</a></li>
                    <li class="breadcrumb-item active text-white" aria-current="page">Oyuncular</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-0">Oyuncu Yönetimi</h2>
        </div>
        <a href="/Players/Create" class="btn btn-primary rounded-pill px-4 py-2">
            <i class="bi bi-plus-lg me-2"></i> Yeni Oyuncu Ekle
        </a>
    </div>

    <div class="card bg-dark border-secondary rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead class="bg-black">
                    <tr class="text-secondary">
                        <th class="ps-4">Profil</th>
                        <th>Ad Soyad</th>
                        <th>Pozisyon</th>
                        <th>Milliyet</th>
                        <th>Yaş</th>
                        <th>Kulüp</th>
                        <th>Piyasa Değeri</th>
                        <th class="text-end pe-4">Aksiyonlar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var player in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="rounded-circle overflow-hidden bg-secondary d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; border: 2px solid var(--accent-color);">
                                    @if (!string.IsNullOrEmpty(player.ImageUrl))
                                    {
                                        <img src="@player.ImageUrl" class="img-fluid" alt="">
                                    }
                                    else
                                    {
                                        <i class="bi bi-person text-white opacity-25"></i>
                                    }
                                </div>
                            </td>
                            <td><span class="fw-bold">@player.FullName</span></td>
                            <td><span class="badge bg-dark border border-secondary">@player.Position</span></td>
                            <td>@player.Nationality</td>
                            <td>@player.Age</td>
                            <td>@(player.CurrentClubName ?? "Kulüpsüz")</td>
                            <td class="text-warning fw-bold">@player.MarketValue</td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a href="/Admin/Players/Edit/@player.Id" class="btn btn-sm btn-outline-info rounded-start-pill px-3">
                                        <i class="bi bi-pencil"></i> Düzenle
                                    </a>
                                    <button onclick="deletePlayer('@player.Id')" class="btn btn-sm btn-outline-danger rounded-end-pill px-3">
                                        <i class="bi bi-trash"></i> Sil
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deletePlayer(id) {
            if (confirm('Bu oyuncuyu silmek istediğinize emin misiniz?')) {
                fetch('/Admin/Players/Delete/' + id, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) location.reload();
                    });
            }
        }
    </script>
}
