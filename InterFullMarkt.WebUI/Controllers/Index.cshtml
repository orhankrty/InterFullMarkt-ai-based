@model List<InterFullMarkt.Application.DTOs.ClubDto>
@{
    ViewData["Title"] = "Kulüpler";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="display-5 fw-bold">
            <i class="bi bi-building"></i> Kulüpler
        </h1>
        <p class="text-secondary">Sistemde kayıtlı elit futbol kulüpleri ve istatistikleri.</p>
    </div>
</div>

<div class="row g-4">
    @foreach (var club in Model)
    {
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 border-0 shadow-sm transition-hover" style="background-color: #1a1f3a;">
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(club.LogoUrl))
                    {
                        <img src="@club.LogoUrl" alt="@club.Name" class="img-fluid mb-3" style="height: 120px; object-fit: contain;">
                    }
                    <h4 class="fw-bold mb-1">@club.Name <span class="badge bg-secondary text-dark fs-6">@club.ShortName</span></h4>
                    <p class="text-muted small mb-4">Est. @club.FoundingYear | @club.StadiumName</p>
                    
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <div class="p-2 rounded" style="background-color: rgba(0, 102, 255, 0.1);">
                                <div class="text-secondary small">Kadro Genişliği</div>
                                <div class="fw-bold fs-5 text-white">@club.SquadCount <i class="bi bi-people-fill"></i></div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-2 rounded" style="background-color: rgba(255, 215, 0, 0.1);">
                                <div class="text-secondary small">Kadro Değeri</div>
                                <div class="fw-bold fs-5 text-warning">
                                    @(club.TotalSquadValue.HasValue ? $"€{(club.TotalSquadValue.Value / 1_000_000):F1}M" : "-")
                                </div>
                            </div>
                        </div>
                    </div>

                    <button class="btn btn-outline-primary w-100 mt-2">
                        <i class="bi bi-info-circle"></i> Kulüp Detayları
                    </button>
                </div>
            </div>
        </div>
    }
</div>